# Generate a strong value, for example: python -c "import secrets; print(secrets.token_hex(32))"
CDE_SECRET_KEY=replace-with-a-long-random-secret

# Initial administrator account. Change the password immediately after first login.
CDE_ADMIN_EMAIL=admin@example.com
CDE_ADMIN_PASSWORD=replace-with-a-strong-password
CDE_ADMIN_NAME=System Administrator

# Local paths and URLs
CDE_ZARR_DIR=./storage/zarr
CDE_LOCAL_BASE_URL=http://127.0.0.1:5000
CDE_PUBLIC_BASE_URL=http://127.0.0.1:5000
CDE_MAX_PRODUCT_REQUESTS=1
