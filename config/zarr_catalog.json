{
  "CHIRPS": {
    "label": "CHIRPS Precipitation",
    "description": "CHIRPS satellite rainfall over Tanzania. Prepared CDE files provide daily, monthly, annual and seasonal rainfall totals. Stores are mapped from storage/zarr/<resolution> subfolders.",
    "time_coord": "time",
    "lat_coord": "latitude",
    "lon_coord": "longitude",
    "supported_frequencies": [
      "daily",
      "monthly",
      "annual",
      "seasonal"
    ],
    "file_patterns": {
      "daily": "daily/CDE_CHIRPS_Tanzania_Rainfall_1981_2025_Daily_Total.zarr",
      "monthly": "monthly/CDE_CHIRPS_Tanzania_Rainfall_1981_2025_Monthly_Total.zarr",
      "annual": "annual/CDE_CHIRPS_Tanzania_Rainfall_1981_2025_Annual_Total.zarr",
      "seasonal": "seasonal/CDE_CHIRPS_Tanzania_Rainfall_1981_2025_Seasonal_{season}_Total.zarr"
    },
    "variables": {
      "precip": {
        "label": "CHIRPS Precipitation",
        "unit": "mm",
        "conversion": "none",
        "daily_aggregation": "sum",
        "period_aggregation": "sum",
        "candidate_names": [
          "precip",
          "rainfall",
          "precipitation"
        ]
      }
    },
    "storage_format": "Zarr",
    "chunked_access": true
  },
  "ERA5_TEMP": {
    "label": "ERA5 2m Temperature",
    "description": "ERA5 2m air temperature. Hourly data are read from ERA5_Tanzania_Temperature_2M_Hourly_1940_2026.zarr. Daily, monthly, annual and seasonal products are read from the prepared CDE ERA5 temperature Mean/Minimum/Maximum stores.",
    "time_coord": "valid_time",
    "lat_coord": "latitude",
    "lon_coord": "longitude",
    "supported_frequencies": [
      "hourly",
      "daily",
      "monthly",
      "annual",
      "seasonal"
    ],
    "file_patterns": {
      "hourly": "hourly/ERA5_Tanzania_Temperature_2M_Hourly_1940_2026.zarr",
      "daily": "daily/CDE_ERA5_Tanzania_Temperature_Mean_Min_Max_1940_2025*.zarr",
      "monthly": "monthly/CDE_ERA5_Tanzania_Temperature_Mean_Min_Max_1940_2025*.zarr",
      "annual": "annual/CDE_ERA5_Tanzania_Temperature_Mean_Min_Max_1940_2025*.zarr",
      "seasonal": "seasonal/CDE_ERA5_Tanzania_Temperature_Mean_Min_Max_1940_2025*{season}*.zarr"
    },
    "variables": {
      "ta": {
        "label": "Mean 2m Temperature",
        "unit": "°C",
        "conversion": "auto_kelvin_to_celsius",
        "daily_aggregation": "mean",
        "period_aggregation": "mean",
        "candidate_names": [
          "ta",
          "t2m",
          "tmean",
          "mean_temperature",
          "temperature_2m",
          "2m_temperature",
          "temperature"
        ]
      }
    },
    "storage_format": "Zarr",
    "chunked_access": true
  },
